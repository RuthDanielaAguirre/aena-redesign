---
import AirportSearch from '../components/AirportSearch.svelte';
import LangSwitcher from '../components/LangSwitcher.svelte';
import { t } from '../i18n/translations';
const lang = 'es';
const i = t[lang];
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Aena — {i.nav.passengers}</title>
  <link rel="alternate" hreflang="es" href="/" />
  <link rel="alternate" hreflang="en" href="/en/" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet" />
</head>
<body>

  <header id="site-header">
    <div class="header-inner">
      <a href="/" class="logo" aria-label={i.a11y.home}>aena</a>
      <nav aria-label={i.a11y.mainNav}>
        <a href="#">{i.nav.passengers}</a>
        <a href="#">{i.nav.airlines}</a>
        <a href="#">{i.nav.corporate}</a>
      </nav>
      <LangSwitcher currentLang={lang} navLabel={i.a11y.langSwitcher} client:load />
    </div>
  </header>

  <section class="hero" aria-label={i.hero.eyebrow}>
    <div class="slides" aria-hidden="true">
      <div class="slide active" style="background-image: url('https://images.unsplash.com/photo-1436491865332-7a61a109cc05?w=1600&q=80')"><div class="slide-label">Madrid · Barajas</div></div>
      <div class="slide" style="background-image: url('https://images.unsplash.com/photo-1569154941061-e231b4725ef1?w=1600&q=80')"><div class="slide-label">Barcelona · El Prat</div></div>
      <div class="slide" style="background-image: url('https://images.unsplash.com/photo-1544620347-c4fd4a3d5957?w=1600&q=80')"><div class="slide-label">Palma · Mallorca</div></div>
      <div class="slide" style="background-image: url('https://images.unsplash.com/photo-1483450388369-9ed95738483c?w=1600&q=80')"><div class="slide-label">Tenerife · Sur</div></div>
    </div>
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="hero-content">
      <p class="hero-eyebrow">{i.hero.eyebrow}</p>
      <h1>{i.hero.title}<br/><em>{i.hero.titleEm}</em></h1>
      <p class="hero-sub">{i.hero.sub}</p>
      <AirportSearch client:load labels={i.search} />
    </div>
    <div class="slider-dots" role="tablist" aria-label={i.a11y.slidesRegion}>
      <button class="dot active" data-index="0" role="tab" aria-selected="true" aria-label="Madrid"></button>
      <button class="dot" data-index="1" role="tab" aria-selected="false" aria-label="Barcelona"></button>
      <button class="dot" data-index="2" role="tab" aria-selected="false" aria-label="Mallorca"></button>
      <button class="dot" data-index="3" role="tab" aria-selected="false" aria-label="Tenerife"></button>
    </div>
  </section>

  <section class="stats" aria-label={i.a11y.statsRegion}>
    <div class="stats-inner">
      <div class="stat"><span class="stat-num">46</span><span class="stat-label">{i.stats.airports}</span></div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat"><span class="stat-num">275M</span><span class="stat-label">{i.stats.passengers}</span></div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat"><span class="stat-num">2.500+</span><span class="stat-label">{i.stats.destinations}</span></div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat"><span class="stat-num">24/7</span><span class="stat-label">{i.stats.realtime}</span></div>
    </div>
  </section>

  <section class="parking" aria-labelledby="parking-title">
    <div class="parking-inner">
      <div class="parking-text">
        <p class="section-eyebrow">{i.parking.eyebrow}</p>
        <h2 id="parking-title">{i.parking.title}<br/>{i.parking.titleLine2}</h2>
        <p class="parking-desc">{i.parking.desc} <strong>4€/día</strong>.</p>
        <div class="parking-btns">
          <a href="#" class="btn btn--primary">{i.parking.cta}</a>
          <a href="#" class="btn btn--ghost">{i.parking.rates}</a>
        </div>
      </div>
      <form class="parking-form" aria-labelledby="parking-form-title" action="#" method="get">
        <p id="parking-form-title" class="form-title">{i.parking.formTitle}</p>
        <div class="form-group">
          <label for="parking-airport">{i.parking.airport}</label>
          <select id="parking-airport" name="airport">
            <option value="">{i.parking.airportPlaceholder}</option>
            <option>Madrid-Barajas (MAD)</option>
            <option>Barcelona-El Prat (BCN)</option>
            <option>Málaga-Costa del Sol (AGP)</option>
            <option>Palma de Mallorca (PMI)</option>
            <option>Alicante-Elche (ALC)</option>
          </select>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="parking-in">{i.parking.checkin}</label>
            <input type="date" id="parking-in" name="checkin" />
          </div>
          <div class="form-group">
            <label for="parking-out">{i.parking.checkout}</label>
            <input type="date" id="parking-out" name="checkout" />
          </div>
        </div>
        <button class="btn btn--primary btn--full" type="submit">{i.parking.submit}</button>
      </form>
    </div>
  </section>

  <section class="vip" aria-labelledby="vip-title">
    <div class="vip-hero">
      <div class="vip-hero-img" style="background-image: url('https://images.unsplash.com/photo-1583416750470-965b2707b355?w=1600&q=80')" aria-hidden="true"></div>
      <div class="vip-hero-overlay" aria-hidden="true"></div>
      <div class="vip-hero-content">
        <p class="vip-eyebrow">{i.vip.eyebrow}</p>
        <h2 id="vip-title">{i.vip.title}<br/><em>{i.vip.titleEm}</em></h2>
        <p class="vip-lead">{i.vip.lead}</p>
        <div class="vip-ctas">
          <a href="#" class="btn btn--primary">{i.vip.ctaPrimary}</a>
          <a href="#" class="btn btn--ghost">{i.vip.ctaSecondary}</a>
        </div>
      </div>
    </div>
    <div class="vip-details" aria-label={i.vip.eyebrow}>
      {i.vip.cards.map((card) => (
        <a href="#" class="vip-card" aria-label={card.aria}>
          <div class="vip-card-img" style={`background-image: url('${card.img}')`} aria-hidden="true"></div>
          <div class="vip-card-body">
            <span class="vip-card-tag">{card.tag}</span>
            <h3>{card.title}</h3>
            <p>{card.desc}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="info" aria-labelledby="info-title">
    <div class="info-inner">
      <div class="info-header">
        <p class="section-eyebrow">{i.info.eyebrow}</p>
        <h2 id="info-title">{i.info.title}<br/>{i.info.titleLine2}</h2>
      </div>
      <div class="info-grid">
        <a href="#" class="info-card info-card--wide" aria-label={i.info.cards[0].title}>
          <div class="info-card-img" style="background-image: url('https://images.unsplash.com/photo-1553361371-9b22f78e8b1d?w=800&q=80')" aria-hidden="true"></div>
          <div class="info-card-body">
            <span class="info-tag">{i.info.cards[0].tag}</span>
            <h3>{i.info.cards[0].title}</h3>
            <p>{i.info.cards[0].desc}</p>
            <span class="info-link">{i.info.more}</span>
          </div>
        </a>
        {i.info.cards.slice(1).map((card, idx) => {
          const imgs = [
            'https://images.unsplash.com/photo-1578575437130-527eed3abbec?w=600&q=80',
            'https://images.unsplash.com/photo-1532629345422-7515f3d16bb6?w=600&q=80',
            'https://images.unsplash.com/photo-1587300003388-59208cc962cb?w=600&q=80',
            'https://images.unsplash.com/photo-1474487548417-781cb71495f3?w=600&q=80',
            'https://images.unsplash.com/photo-1583416750470-965b2707b355?w=600&q=80',
          ];
          const isLast = idx === 4;
          return (
            <a href="#" class="info-card info-card--img" aria-label={card.title} style={`background-image: url('${imgs[idx]}')`}>
              <div class={`info-card-overlay${isLast ? ' info-card-overlay--gold' : ''}`} aria-hidden="true"></div>
              <div class="info-card-body">
                <span class={`info-tag${isLast ? ' info-tag--light' : ''}`}>{card.tag}</span>
                <h3>{card.title}</h3>
                <p>{card.desc}</p>
                <span class="info-link">{isLast ? i.info.discover : i.info.more}</span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <section class="market" aria-label={i.a11y.marketRegion}>
    <div class="market-inner">
      <a href="#" class="market-card" aria-label={i.a11y.shopCard} style="background-image: url('https://images.unsplash.com/photo-1483985988355-763728e1935b?w=900&q=80')">
        <div class="market-overlay" aria-hidden="true"></div>
        <div class="market-card-content">
          <span class="market-eyebrow">Aena Market</span>
          <h3>Shop<br/><em>to Fly</em></h3>
          <p>{i.market.shopDesc}</p>
          <span class="btn btn--primary">{i.market.shopCta}</span>
        </div>
      </a>
      <a href="#" class="market-card" aria-label={i.a11y.foodCard} style="background-image: url('https://images.unsplash.com/photo-1504674900247-0877df9cc836?w=900&q=80')">
        <div class="market-overlay market-overlay--food" aria-hidden="true"></div>
        <div class="market-card-content">
          <span class="market-eyebrow">Aena Market</span>
          <h3>Food<br/><em>to Fly</em></h3>
          <p>{i.market.foodDesc}</p>
          <span class="btn btn--primary">{i.market.foodCta}</span>
        </div>
      </a>
    </div>
  </section>

  <footer>
    <div class="footer-inner">
      <div class="footer-top">
        <div class="footer-brand">
          <a href="/" class="footer-logo" aria-label={i.a11y.home}>aena</a>
          <p class="footer-tagline">{i.footer.tagline}</p>
          <div class="footer-social" aria-label={i.a11y.footerSocial}>
            <a href="https://instagram.com/aena_aeropuertos" target="_blank" rel="noopener" aria-label={i.footer.instagramAria} class="social-btn"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg></a>
            <a href="https://twitter.com/aena_airports" target="_blank" rel="noopener" aria-label={i.footer.xAria} class="social-btn"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg></a>
            <a href="https://facebook.com/aena" target="_blank" rel="noopener" aria-label={i.footer.facebookAria} class="social-btn"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg></a>
            <a href="https://youtube.com/aena" target="_blank" rel="noopener" aria-label={i.footer.youtubeAria} class="social-btn"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.495 6.205a3.007 3.007 0 0 0-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 0 0 .527 6.205a31.247 31.247 0 0 0-.522 5.805 31.247 31.247 0 0 0 .522 5.783 3.007 3.007 0 0 0 2.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 0 0 2.088-2.088 31.247 31.247 0 0 0 .5-5.783 31.247 31.247 0 0 0-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/></svg></a>
            <a href="https://linkedin.com/company/aena" target="_blank" rel="noopener" aria-label={i.footer.linkedinAria} class="social-btn"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg></a>
          </div>
        </div>
        <nav class="footer-nav" aria-label={i.a11y.footerLinks}>
          <div class="footer-col">
            <p class="footer-col-title">{i.footer.colPassengers}</p>
            <a href="#">{i.footer.linkBaggage}</a>
            <a href="#">{i.footer.linkSecurity}</a>
            <a href="#">{i.footer.linkParking}</a>
            <a href="#">{i.footer.linkAccessibility}</a>
          </div>
          <div class="footer-col">
            <p class="footer-col-title">{i.footer.colAirports}</p>
            <a href="#">{i.footer.linkMad}</a>
            <a href="#">{i.footer.linkBcn}</a>
            <a href="#">{i.footer.linkPmi}</a>
            <a href="#">{i.footer.linkAllAirports}</a>
          </div>
          <div class="footer-col">
            <p class="footer-col-title">{i.footer.colCompany}</p>
            <a href="#">{i.footer.linkAbout}</a>
            <a href="#">{i.footer.linkCorporate}</a>
            <a href="#">{i.footer.linkSustainability}</a>
            <a href="#">{i.footer.linkPress}</a>
          </div>
        </nav>
      </div>
      <div class="footer-bottom">
        <p class="footer-copy">{i.footer.copy}</p>
        <nav aria-label={i.a11y.footerLegal}>
          <a href="#">{i.footer.legal}</a>
          <a href="#">{i.footer.privacy}</a>
          <a href="#">{i.footer.accessibility}</a>
          <a href="#">{i.footer.contact}</a>
        </nav>
      </div>
    </div>
  </footer>

</body>
</html>

<style is:global>
  :root {
    --color-primary: #96ce00;
    --color-bg: #1a2732;
    --color-bg-dark: #111d27;
    --color-bg-card: #253444;
    --color-text: #fff;
    --color-text-muted: #d4dce6;
    --color-text-soft: #c2ceda;
    --color-text-subtle: #aebdcb;
    --color-text-legal: #a8b7c8;
    --color-border: rgba(150,206,0,0.15);
    --color-border-solid: rgba(255,255,255,0.08);
    --font-sans: 'DM Sans', sans-serif;
    --font-serif: 'DM Serif Display', serif;
    --radius: 16px;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: var(--font-sans); background: var(--color-bg); color: var(--color-text); }

  /* HEADER */
  #site-header { position: fixed; top: 0; left: 0; right: 0; z-index: 100; padding: 0 2rem; transition: background 0.3s, border-color 0.3s; border-bottom: 1px solid transparent; }
  #site-header.scrolled { background: var(--color-bg-dark); border-color: var(--color-border); }
  .header-inner { max-width: 1200px; margin: 0 auto; display: flex; align-items: center; gap: 2rem; height: 70px; }
  .logo { font-family: var(--font-serif); font-size: 2rem; color: var(--color-primary); margin-right: auto; text-decoration: none; }
  .logo:focus-visible { outline: 2px solid var(--color-primary); outline-offset: 4px; border-radius: 4px; }
  nav { display: flex; gap: 2rem; }
  nav a { color: #e8edf2; text-decoration: none; font-size: 0.9rem; font-weight: 500; transition: color 0.2s; text-shadow: 0 1px 2px rgba(0,0,0,0.55); }
  nav a:hover, nav a:focus-visible { color: var(--color-primary); }
  nav a:focus-visible { outline: 2px solid var(--color-primary); outline-offset: 3px; border-radius: 4px; }

  /* HERO */
  .hero { position: relative; height: 100vh; min-height: 600px; display: flex; align-items: center; justify-content: center; overflow: hidden; }
  .slides { position: absolute; inset: 0; }
  .slide { position: absolute; inset: 0; background-size: cover; background-position: center; opacity: 0; transition: opacity 1.2s ease; }
  .slide.active { opacity: 1; }
  .slide-label { position: absolute; bottom: 5rem; right: 2rem; color: #e8eef5; font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; text-shadow: 0 1px 4px rgba(0,0,0,0.85); }
  .hero-overlay { position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(17,29,39,0.3) 0%, rgba(17,29,39,0.6) 55%, rgba(26,39,50,1) 100%); }
  .hero-content { position: relative; z-index: 2; text-align: center; max-width: 720px; padding: 0 2rem; }
  .hero-eyebrow { color: var(--color-primary); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; margin-bottom: 1.25rem; }
  h1 { font-family: var(--font-serif); font-size: clamp(2.8rem, 7vw, 5rem); color: #fff; line-height: 1.05; margin-bottom: 1rem; }
  h1 em { color: var(--color-primary); font-style: italic; }
  .hero-sub { color: var(--color-text-muted); font-size: 1.05rem; margin-bottom: 2.5rem; }
  .slider-dots { position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%); display: flex; gap: 0.5rem; z-index: 3; }
  .dot { width: 8px; height: 8px; border-radius: 50%; border: none; background: rgba(255,255,255,0.55); cursor: pointer; transition: all 0.3s; padding: 0; }
  .dot:focus-visible { outline: 2px solid var(--color-primary); outline-offset: 3px; }
  .dot.active { background: var(--color-primary); width: 24px; border-radius: 4px; }

  /* STATS */
  .stats { background: var(--color-bg-dark); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); padding: 2rem; }
  .stats-inner { max-width: 1200px; margin: 0 auto; display: flex; align-items: center; justify-content: center; gap: 3rem; flex-wrap: wrap; }
  .stat { display: flex; flex-direction: column; align-items: center; gap: 0.25rem; }
  .stat-num { font-family: var(--font-serif); font-size: 2rem; color: var(--color-primary); line-height: 1; }
  .stat-label { font-size: 0.72rem; color: var(--color-text-soft); text-transform: uppercase; letter-spacing: 0.08em; }
  .stat-divider { width: 1px; height: 40px; background: var(--color-border); }

  /* BTNS */
  .btn { display: inline-flex; align-items: center; padding: 0.8rem 1.6rem; border-radius: 10px; font-family: var(--font-sans); font-size: 0.9rem; font-weight: 600; text-decoration: none; cursor: pointer; border: none; transition: all 0.2s; }
  .btn:focus-visible { outline: 2px solid var(--color-primary); outline-offset: 3px; }
  .btn--primary { background: var(--color-primary); color: #111d27; }
  .btn--primary:hover { background: #a8e000; }
  .btn--ghost { background: transparent; color: var(--color-text); border: 1px solid var(--color-border-solid); }
  .btn--ghost:hover { border-color: var(--color-primary); color: var(--color-primary); }
  .btn--full { width: 100%; justify-content: center; }

  /* PARKING */
  .parking { padding: 6rem 2rem; }
  .parking-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  .section-eyebrow { color: var(--color-primary); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 1rem; }
  .parking-text h2 { font-family: var(--font-serif); font-size: clamp(1.8rem, 3vw, 2.8rem); line-height: 1.1; margin-bottom: 1.25rem; }
  .parking-desc { color: var(--color-text-muted); font-size: 1rem; line-height: 1.7; margin-bottom: 2rem; }
  .parking-desc strong { color: var(--color-primary); }
  .parking-btns { display: flex; gap: 1rem; flex-wrap: wrap; }
  .parking-form { background: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: var(--radius); padding: 2rem; }
  .form-title { font-weight: 700; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-primary); margin-bottom: 1.5rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .form-row .form-group { margin-bottom: 1rem; }
  label { font-size: 0.78rem; font-weight: 600; color: var(--color-text-soft); text-transform: uppercase; letter-spacing: 0.06em; }
  select, input[type="date"] { background: var(--color-bg); border: 1px solid var(--color-border-solid); border-radius: 8px; color: var(--color-text); padding: 0.7rem 0.9rem; font-family: var(--font-sans); font-size: 0.9rem; transition: border-color 0.2s; width: 100%; }
  select:focus, input[type="date"]:focus { outline: none; border-color: var(--color-primary); }
  select option { background: var(--color-bg-dark); }

  /* VIP */
  .vip { background: var(--color-bg-dark); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); }
  .vip-hero { position: relative; height: 85vh; min-height: 520px; display: flex; align-items: flex-end; overflow: hidden; }
